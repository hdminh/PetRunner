{
  "name": "@hdminh/pet-runner",
  "version": "0.3.0",
  "description": "Build and run PetRunner locally on macOS and Windows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pet-runner": "bin/pet-runner.js"
  },
  "files": [
    "bin/",
    "lib/",
    "Assets/",
    "DashboardWeb/",
    "Sources/",
    "Support/",
    "windows/",
    "THIRD_PARTY_NOTICES.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/cli.test.js",
    "pack:check": "npm pack --dry-run",
    "dashboard:dev": "vite --config DashboardWeb/vite.config.ts",
    "dashboard:build": "vite build --config DashboardWeb/vite.config.ts",
    "dashboard:typecheck": "tsc --project DashboardWeb/tsconfig.json --noEmit",
    "dashboard:test": "vitest run --config DashboardWeb/vitest.config.ts"
  },
  "engines": {
    "node": ">=20.19"
  },
  "os": [
    "darwin",
    "win32"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdminh/PetRunner.git"
  },
  "keywords": [
    "pet",
    "desktop-pet",
    "codex"
  ],
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^8.0.0"
  }
}
