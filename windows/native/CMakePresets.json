{
  "version": 3,
  "configurePresets": [
    {
      "name": "release-x64",
      "displayName": "Release x64",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../../.build/windows-native-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${env:VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    }
  ],
  "buildPresets": [
    { "name": "release-x64", "configurePreset": "release-x64" }
  ],
  "testPresets": [
    { "name": "release-x64", "configurePreset": "release-x64", "output": { "outputOnFailure": true } }
  ]
}
